# ============================================================================
# GIT IGNORE - EXCLUDE FROM VERSION CONTROL
# ============================================================================
# Files/directories that should NOT be committed to git:
#   - Secrets (passwords, API keys, .env files)
#   - Virtual environments
#   - Generated logs/output
#   - IDE/editor configs
#   - OS-specific files
# ============================================================================

# ============ SECURITY - SECRETS & CREDENTIALS ============
.env
.env.local
*.key
*.pem
secrets.yaml
credentials.json

# ============ PYTHON ENVIRONMENTS ============
venv/
env/
*.venv/
ENV/
env.bak/
venv.bak/

# ============ PYTHON GENERATED FILES ============
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============ TESTING & COVERAGE ============
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ============ IDE & EDITOR FILES ============
.vscode/
.idea/
*.swp
*.swo
*~ 
.DS_Store
Thumbs.db

# ============ PROJECT-SPECIFIC ============
internal_testing/*
*.log
backups/
*.backup
.tmp/
nornir.log